<Page x:Class="LABA16MDK1.PAGE.Task2Page"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LABA16MDK1.PAGE"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
            Title="Задание 2: Шаблоны">
    <Page.Resources>
        <ControlTemplate x:Key="CustomRoundButton" TargetType="Button">
            <Grid>
                <Ellipse x:Name="OuterCircle" Fill="LightGray" Stroke="Black" StrokeThickness="2"/>
                <Ellipse x:Name="InnerCircle" Fill="White" Margin="10"/>
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="InnerCircle" Property="Fill" Value="LightBlue"/>
                    <Setter TargetName="OuterCircle" Property="Fill" Value="DarkGray"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="InnerCircle" Property="Fill" Value="Orange"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Page.Resources>
    <Grid Background="White">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Кнопка с использованием ControlTemplate и TargetName" Margin="10" FontWeight="Bold"/>
            <Button Template="{StaticResource CustomRoundButton}" Content="Нажми меня" Width="150" Height="150"/>
        </StackPanel>
    </Grid>
</Page>
